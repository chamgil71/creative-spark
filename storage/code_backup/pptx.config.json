{
  // ════════════════════════════════════════════════════════════════
  //  html-to-pptx.mjs 전체 파라미터 설정 파일
  //  주석(//)은 스크립트 로더가 자동으로 제거합니다.
  // ════════════════════════════════════════════════════════════════

  // ── 섹션 셀렉터 ──────────────────────────────────────────────────
  // 슬라이드 한 장으로 분리할 기준 요소 목록 (우선순위 순).
  // 두 가지 HTML 패턴 모두 지원:
  //   Type A (notion, obsidian): <section class="section">
  //   Type B (claude, chatgpt):  <div class="section">
  // 히어로/마무리 섹션도 별도 슬라이드로 생성됩니다.
  // 변경 예시: h2 기준으로 나누고 싶다면 ["h2"] 로 교체
  "sectionSelectors": [
    "section.hero",
    "section.section",
    "div.section",
    "section.done-section"
  ],

  // 섹션 제목으로 쓸 요소 셀렉터 (우선순위 순, 첫 번째 매칭 사용)
  //   h2.section-title  → Type A 패턴 (notion, obsidian)
  //   .section-header h2 → Type B 패턴 (claude, chatgpt)
  "titleSelectors": [
    "h2.section-title",
    ".section-header h2",
    "h1",
    "h2"
  ],

  // 섹션 내부 콘텐츠 래퍼 셀렉터 (있으면 그 안만 파싱, 없으면 섹션 전체 파싱)
  //   .section-inner → Type A 패턴에서 사용
  "innerSelectors": [".section-inner"],

  // 변환 전 DOM에서 제거할 요소 (네비게이션, 푸터, 뒤로가기 버튼 등)
  "ignoreSelector": "nav, footer, .back-top, .nav, .nav-inner, script",

  // ── 슬라이드 크기 ────────────────────────────────────────────────
  // "LAYOUT_WIDE" : 13.333" × 7.5"  (16:9 와이드, 기본값)
  // "LAYOUT_4x3"  : 10" × 7.5"     (4:3 표준)
  // "LAYOUT_A4"   : A4 세로
  "slideLayout": "LAYOUT_WIDE",

  // 슬라이드 치수 및 기본 폰트 설정
  "slide": {
    "widthIn":      13.333,
    "heightIn":     7.5,
    "font":         "Malgun Gothic",
    "fontMono":     "Consolas",
    // 좌우 여백 (인치)
    "marginX":      0.5,
    // 슬라이드 제목 아래 콘텐츠 시작 Y 위치 (인치)
    "bodyTopY":     1.3,
    // 페이지 번호 위쪽 경계 (인치)
    "bodyBottomY":  7.15
  },

  // ── 폰트 크기 (pt 단위) ──────────────────────────────────────────
  "fontSize": {
    "slideTitle":  24,
    "h3":          15,
    "body":        12,
    "small":       10,
    "code":        10,
    "badge":        9
  },

  // ── 색상 소스 ────────────────────────────────────────────────────
  // "html"        : HTML <style> :root CSS 변수에서 자동 추출 (기본값)
  //                 파일마다 다른 브랜드 색상을 그대로 반영합니다.
  // "styles-json" : templates/styles.json 프리셋 키(styleKey)를 사용합니다.
  //                 CLI --style 옵션으로도 덮어쓸 수 있습니다.
  "colorSource": "html",

  // colorSource가 "styles-json"일 때 사용할 키
  // 가능한 값: "ai-chat" | "ai-dev" | "knowledge" | "productivity" | "creative"
  "styleKey": "ai-chat",

  // CSS 변수 → PPT 색상 역할 매핑
  // 각 역할마다 후보 변수 이름을 우선순위 순으로 나열합니다.
  // 파일마다 변수명이 달라도 자동으로 첫 번째 매칭을 사용합니다.
  //   Claude/ChatGPT: --brand, --brand-light, --brand-dark
  //   Notion:         --accent, --accent-light
  //   Obsidian:       --purple, --purple-light, --purple-dark
  "cssVarMapping": {
    "brand":      ["--brand", "--purple", "--accent", "--black"],
    "brandLight": ["--brand-light", "--purple-light", "--accent-light", "--gray-light"],
    "brandDark":  ["--brand-dark", "--purple-dark", "--gray-dark"],
    "bg":         ["--bg", "--gray-bg"],
    "border":     ["--border"],
    "text":       ["--text"],
    "textMuted":  ["--text-2", "--text-3", "--gray-mid"]
  },

  // CSS 추출에 실패했을 때 사용할 기본 색상 팔레트 (hex, # 없음)
  "defaultColors": {
    "bgDark":      "0F172A",
    "accent":      "6366F1",
    "accentDark":  "4338CA",
    "accentLight": "EEF2FF",
    "title":       "0F172A",
    "body":        "334155",
    "muted":       "64748B",
    "cardBg":      "F8FAFC",
    "cardBorder":  "E2E8F0",
    "codeBg":      "0F172A",
    "codeText":    "E2E8F0",
    "white":       "FFFFFF",
    "slideBg":     "FFFFFF"
  },

  // ── 카드 인식 클래스 ─────────────────────────────────────────────
  // 이 목록의 클래스 중 하나라도 가지면 "card 블록"으로 처리합니다.
  // ※ 새 HTML 파일에 새 카드 클래스가 추가되면 여기에 추가하세요.
  "cardClasses": [
    // Claude/ChatGPT 계열
    "model-card", "project-card", "skill-item", "integration-item",
    "plan-card", "gpt-tool", "mt-item", "memory-item", "memory-demo",
    // Notion/Obsidian 계열
    "block-card", "view-card", "ai-feature", "shortcut-group",
    "concept-card", "feature-item", "plugin-card", "ai-card",
    // 공통
    "card", "tip-box", "prompt-box", "system-prompt-demo"
  ],

  // ── 그리드 컨테이너 클래스 ───────────────────────────────────────
  // 이 클래스를 가진 요소 내부의 카드들을 가로 배치(grid 블록)로 처리합니다.
  // ※ 새 그리드 클래스가 생기면 여기에 추가하세요.
  "gridClasses": [
    // Claude/ChatGPT 계열
    "grid-2", "grid-3", "skill-grid", "integration-grid",
    "plan-grid", "gpt-tool-grid", "memory-items",
    // Notion/Obsidian 계열
    "block-grid", "view-grid", "ai-features",
    "shortcut-grid", "concept-grid", "plugin-grid",
    // 기타 패턴
    "model-timeline"
  ],

  // ── 그리드 렌더링 설정 ───────────────────────────────────────────
  "grid": {
    // 카드 한 장의 최소 폭 (인치).
    // overflowBehavior: "allow"이면 슬라이드 폭을 초과해도 이 값을 유지합니다.
    "cardMinW":  2.8,

    // 한 행에 배치할 최대 열 수.
    // 아이템 수가 이보다 많으면 다음 행으로 넘어갑니다.
    "cardMaxCols": 4,

    // 카드 고정 높이 (인치). 내용이 넘쳐도 잘리지 않습니다 (PPT에서 직접 편집).
    "cardH":     1.6,

    // 카드 간 수평 간격 (인치)
    "gapX":      0.15,

    // 카드 행 간 수직 간격 (인치)
    "gapY":      0.15,

    // 슬라이드 가로 폭 초과 시 처리 방식:
    //   "allow" : 폭을 초과해도 그대로 배치. PowerPoint에서 직접 수정.
    //   "warn"  : 콘솔에 경고를 출력하되, "allow"와 동일하게 처리.
    "overflowBehavior": "warn"
  },

  // ── 블록 공통 렌더링 설정 ────────────────────────────────────────
  "blocks": {
    // 블록 간 수직 여백 (인치)
    "gap":           0.12,
    // 카드 내부 좌우 패딩 (인치)
    "cardPadX":      0.2,
    // 카드 내부 상하 패딩 (인치)
    "cardPadY":      0.15,
    // 카드 모서리 둥글기 (인치)
    "cardRadius":    0.08,
    // 인용문 좌측 세로 바 폭 (인치)
    "quoteBarW":     0.08,
    // 헤더 바 폭 (인치) — 슬라이드 제목 좌측 강조 바
    "headerBarW":    0.12,
    "h3FontSize":    16,
    "pFontSize":     12,
    "listFontSize":  12,
    "cardTitleSize": 13,
    "cardBodySize":  11,
    "codeTextSize":  10,
    "quoteTextSize": 12
  },

  // ── 표지 슬라이드 설정 ───────────────────────────────────────────
  "cover": {
    // false로 설정하면 표지 슬라이드를 생성하지 않습니다
    "enabled":        true,
    // 서브타이틀 텍스트
    "subtitleText":   "AI 가이드 허브",
    // 서브타이틀 색상 (hex)
    "subtitleColor":  "94A3B8",
    "titleFontSize":  44,
    "subtitleFontSize": 16,
    // 좌측 강조 바 위치/크기 (인치)
    "accentBarX":     0.5,
    "accentBarY":     2.8,
    "accentBarW":     0.18,
    "accentBarH":     1.5
  },

  // ── 슬라이드 헤더 설정 ───────────────────────────────────────────
  "header": {
    "y":             0.45,
    "h":             0.7,
    "barW":          0.12,
    "titleFontSize": 26
  },

  // ── 출력 설정 ────────────────────────────────────────────────────
  "output": {
    // 기본 출력 디렉토리 (--out 옵션으로 파일별 경로 지정 가능)
    "dir":    "dist-pptx",
    // 파일명 접미사 (예: "-v2" → Claude-v2.pptx)
    "suffix": ""
  }
}
