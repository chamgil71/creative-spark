{
  // ════════════════════════════════════════════════════════════════
  //  md-to-pptx.mjs 디자인 설정
  //  색상 프리셋은 templates/styles.json 에서 자동 적용됩니다.
  //  주석(//)은 로더가 자동 제거합니다.
  // ════════════════════════════════════════════════════════════════

  // ── 슬라이드 물리 설정 ────────────────────────────────────────────
  "slide": {
    "layout":      "LAYOUT_WIDE",
    "widthIn":     13.333,
    "heightIn":    7.5,
    "font":        "Malgun Gothic",
    "fontMono":    "Consolas",
    "marginX":     0.5,
    // 헤더 아래 콘텐츠 시작 Y (인치)
    "bodyTopY":    1.25,
    // 슬라이드 하단 경계 Y (인치) — 초과 시 경고
    "bodyBottomY": 7.05
  },

  // ── 표지 슬라이드 ────────────────────────────────────────────────
  "cover": {
    // 좌측 액센트 세로 바
    "accentBarX":       0.5,
    "accentBarY":       2.3,
    "accentBarW":       0.18,
    "accentBarH":       1.7,
    // 제목 시작 위치
    "titleX":           1.0,
    "titleY":           2.4,
    "titleFontSize":    40,
    "subtitleFontSize": 16,
    // 로고 이모지 크기 (pt)
    "logoFontSize":     46
  },

  // ── 섹션 헤더 바 (슬라이드 상단) ────────────────────────────────
  "header": {
    "y":             0.0,
    "h":             1.05,
    "numBoxSize":    0.55,
    "numFontSize":   16,
    "titleFontSize": 22,
    "paddingX":      0.55
  },

  // ── 카드 / 텍스트 블록 ───────────────────────────────────────────
  "card": {
    // 카드 내부 좌우 패딩 (인치)
    "padX":         0.2,
    // 카드 내부 상하 패딩 (인치)
    "padY":         0.18,
    // 블록 간 수직 간격 (인치)
    "gap":          0.12,
    // 카드 모서리 둥글기 (인치)
    "radius":       0.08,
    // 폰트 크기 (pt)
    "titleSize":    13,
    "bodySize":     11,
    "h3Size":       13,
    "h4Size":       12,
    "codeSize":     10,
    // 인용문 좌측 바 폭 (인치)
    "quoteBarW":    0.07,
    "quoteTextSize": 11
  },

  // ── 그리드 / 숏코드 레이아웃 ────────────────────────────────────
  "grid": {
    // 카드 간 간격 (인치)
    "gap":                0.15,
    // icon-grid 카드 최소 폭 (인치) — 열 수 자동 계산에 사용
    "iconCardMinW":       1.8,
    // feature-grid 카드 최소 폭
    "featureCardMinW":    2.6,
    // compare-grid 카드 최소 폭
    "compareCardMinW":    2.2,
    // steps 한 항목 높이 (인치)
    "stepItemH":          0.68
  },

  // ── 출력 경로 ────────────────────────────────────────────────────
  "output": {
    // 기본 출력 디렉토리
    "dir":    "dist-pptx",
    // 파일명 접미사 (예: "-v2" → Supabase-v2.pptx)
    "suffix": ""
  }
}
