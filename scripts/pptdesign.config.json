{
  // ════════════════════════════════════════════════════════════════
  //  md-to-pptx.mjs 디자인 설정
  //  색상 프리셋은 templates/styles.json 에서 자동 적용됩니다.
  //  주석(//)은 로더가 자동 제거합니다.
  // ════════════════════════════════════════════════════════════════

  // ── 슬라이드 물리 설정 ────────────────────────────────────────────
  "slide": {
    "layout":      "LAYOUT_WIDE",
    "widthIn":     13.333,
    "heightIn":    7.5,
    "font":        "Malgun Gothic",
    "fontMono":    "Consolas",
    "marginX":     0.5,
    // 헤더 아래 콘텐츠 시작 Y (인치)
    "bodyTopY":    1.25,
    // 슬라이드 하단 경계 Y (인치) — 초과 시 경고
    "bodyBottomY": 7.05
  },

  // ── 표지 슬라이드 ────────────────────────────────────────────────
  "cover": {
    // 좌측 액센트 세로 바
    "accentBarX":       0.5,
    "accentBarY":       2.3,
    "accentBarW":       0.18,
    "accentBarH":       1.7,
    // 제목 시작 위치
    "titleX":           1.0,
    "titleY":           2.4,
    "titleFontSize":    40,
    "subtitleFontSize": 16,
    // 로고 이모지 크기 (pt)
    "logoFontSize":     46
  },

  // ── 섹션 헤더 바 (슬라이드 상단) ────────────────────────────────
  "header": {
    "y":             0.0,
    "h":             1.05,
    "numBoxSize":    0.55,
    "numFontSize":   16,
    "titleFontSize": 22,
    "paddingX":      0.55
  },

  // ── 카드 / 텍스트 블록 ───────────────────────────────────────────
  "card": {
    // 카드 내부 좌우 패딩 (인치)
    "padX":         0.2,
    // 카드 내부 상하 패딩 (인치)
    "padY":         0.18,
    // 블록 간 수직 간격 (인치)
    "gap":          0.12,
    // 카드 모서리 둥글기 (인치)
    "radius":       0.08,
    // 폰트 크기 (pt)
    "titleSize":    13,
    "bodySize":     11,
    "h3Size":       13,
    "h4Size":       12,
    "codeSize":     10,
    // 인용문 좌측 바 폭 (인치)
    "quoteBarW":    0.07,
    "quoteTextSize": 11
  },

  // ── 그리드 / 숏코드 레이아웃 ────────────────────────────────────
  "grid": {
    // 카드 간 간격 (인치)
    "gap":                0.15,
    // icon-grid 카드 최소 폭 (인치) — 열 수 자동 계산에 사용
    "iconCardMinW":       1.8,
    // feature-grid 카드 최소 폭
    "featureCardMinW":    2.6,
    // compare-grid 카드 최소 폭
    "compareCardMinW":    2.2,
    // steps 한 항목 높이 (인치)
    "stepItemH":          0.68
  },

  // ── 출력 경로 ────────────────────────────────────────────────────
  "output": {
    // 기본 출력 디렉토리
    "dir":    "dist-pptx",
    // 파일명 접미사 (예: "-v2" → Supabase-v2.pptx)
    "suffix": ""
  },

  // ── 고정 색상 팔레트 (브랜드 색 외 공통 색상) ─────────────────────
  "palette": {
    "bgDark":         "0F172A",  // 어두운 배경 (커버·코드블록)
    "white":          "FFFFFF",
    "text":           "1A1A2E",  // 기본 텍스트
    "text2":          "475569",  // 보조 텍스트
    "codeBg":         "0F172A",  // 코드 블록 배경
    "codeText":       "E2E8F0",  // 코드 텍스트
    "codeBorder":     "334155",  // 코드 블록 테두리
    "coverSubtitle":  "94A3B8",  // 표지 부제목
    "coverStatLabel": "64748B",  // 표지 통계 레이블
    "doneSubtitle":   "C0D4E4",  // 마무리 슬라이드 부제목
    "workflowArrow":  "8892B0"   // 워크플로우 화살표
  },

  // ── 워크플로우 숏코드 치수 ────────────────────────────────────────
  "workflow": {
    "stepH":  0.9,
    "arrowW": 0.24
  },

  // ── tool-card 치수 ───────────────────────────────────────────────
  "toolCard": {
    "h": 0.75
  },

  // ── 마무리(done) 슬라이드 치수 ───────────────────────────────────
  "done": {
    "titleY":           2.4,
    "titleH":           1.1,
    "titleFontSize":    32,
    "subtitleY":        3.6,
    "subtitleH":        0.65,
    "subtitleFontSize": 14,
    "ctaY":             4.45,
    "ctaW":             3.2,
    "ctaFontSize":      14
  },

  // ── 신규 숏코드: plan-grid ────────────────────────────────────────
  "planGrid": {
    "maxCols":      4,
    "featureLineH": 0.27   // 기능 항목 한 줄 높이 (인치)
  },

  // ── 신규 숏코드: skill-list ───────────────────────────────────────
  "skillList": {
    "rowH":    0.62,  // 행 높이 (인치)
    "iconSize": 0.38  // 아이콘 박스 크기 (인치)
  },

  // ── 신규 숏코드: badge-grid ───────────────────────────────────────
  "badgeGrid": {
    "minW":  1.3,  // 카드 최소 폭 — 열 수 자동 계산
    "cardH": 1.1   // 카드 높이
  },

  // ── 신규 숏코드: columns (2~5단 좌우 배치) ───────────────────────
  "columns": {
    "maxCols": 5
  },

  // ── 신규 숏코드: bottom-list (하단 요점 칩 배치) ─────────────────
  "bottomList": {
    "chipGap":    0.1,   // 칩 사이 간격
    "chipRadius": 0.12,  // 칩 모서리 둥글기
    "chipPadX":   0.15,  // 칩 내부 좌우 패딩
    "chipH":      0.48   // 칩 높이
  },

  // ── 신규 숏코드: compare-2col (2단 비교 + 하단 여러줄) ───────────
  "compare2col": {
    "colGap":     0.25,  // 두 열 사이 간격
    "noteH":      0.28,  // 하단 note 칩 높이
    "noteRadius": 0.08   // note 칩 모서리 둥글기
  }
}
